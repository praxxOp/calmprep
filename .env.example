# ───────────────────────────────────────────────────────────────
# Saathi — environment variables (TEMPLATE)
# Copy this file to `.env.local` and fill in real values there.
# `.env.local` is gitignored. NEVER put real secrets in this file.
# ───────────────────────────────────────────────────────────────

# Google Gemini (https://aistudio.google.com/apikey)
# SERVER-ONLY. Used in route handlers / server actions. Never exposed to the client.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Supabase (Project Settings → API)
# Safe to expose to the browser (public anon client).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER-ONLY. Bypasses RLS — used only in trusted server code. Never expose.
SUPABASE_SERVICE_ROLE_KEY=
